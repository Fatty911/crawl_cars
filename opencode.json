{
  "$schema": "https://opencode.ai/schema/config.json",
  "provider": [
    {
      "id": "atomgit-free",
      "name": "AtomGit Free",
      "type": "openai-compatible",
      "api_key_env": "ATOMGIT_API_KEY",
      "base_url": "https://api-ai.gitcode.com/v1",
      "whitelist": [
        "zai-org/GLM-5",
        "Qwen/Qwen3.5-397B-A17B"
      ]
    },
    {
      "id": "zen-free",
      "name": "ZEN Free",
      "type": "openai-compatible",
      "api_key_env": "ZEN_API_KEY",
      "base_url": "https://opencode.ai/zen/v1",
      "whitelist": [
        "mimo-v2-pro-free",
        "minimax-m2.5-free",
        "nemotron-3-super-free"
      ]
    },
    {
      "id": "nvidia-nim",
      "name": "NVIDIA NIM",
      "type": "openai-compatible",
      "api_key_env": "NVIDIA_NIM_API_KEY",
      "base_url": "https://integrate.api.nvidia.com/v1",
      "whitelist": [
        "nemotron-3-super"
      ]
    },
    {
      "id": "openrouter-top",
      "name": "OpenRouter Top",
      "type": "openai-compatible",
      "api_key_env": "OPENROUTER_API_KEY",
      "base_url": "https://openrouter.ai/api/v1",
      "whitelist": [
        "google/gemini-3.1-pro-preview",
        "anthropic/claude-opus-4.6",
        "anthropic/claude-sonnet-4.6",
        "openai/gpt-5.4",
        "openai/gpt-5.4-codex",
        "xai/grok-4.20-beta-0309",
        "minimax/minimax-m2.7",
        "deepseek/deepseek-r1"
      ]
    },
    {
      "id": "minimax",
      "name": "MiniMax",
      "type": "openai-compatible",
      "api_key_env": "MINIMAX_API_KEY",
      "base_url": "https://api.minimax.io/v1",
      "whitelist": [
        "minimax-m2.7"
      ]
    },
    {
      "id": "xai",
      "name": "xAI",
      "type": "openai-compatible",
      "api_key_env": "XAI_API_KEY",
      "base_url": "https://api.x.ai/v1",
      "whitelist": [
        "grok-4.20-beta-0309-reasoning"
      ]
    },
    {
      "id": "modal",
      "name": "Modal",
      "type": "openai-compatible",
      "api_key_env": "MODAL_API_KEY",
      "base_url": "https://modal-labs--llm-api-proxy.modal.run/v1",
      "whitelist": [
        "glm-5.1-fp8"
      ]
    },
    {
      "id": "modelscope",
      "name": "ModelScope",
      "type": "openai-compatible",
      "api_key_env": "MODELSCOPE_API_KEY",
      "base_url": "https://dashscope.aliyuncs.com/api/v1",
      "whitelist": [
        "qwen3.5-397b-a17b"
      ]
    },
    {
      "id": "moonshot",
      "name": "Moonshot",
      "type": "openai-compatible",
      "api_key_env": "MOONSHOT_API_KEY",
      "base_url": "https://api.moonshot.cn/v1",
      "whitelist": [
        "moonshot-v1-128k"
      ]
    }
  ],
  "agent": {
    "default": "build",
    "categories": {
      "visual-engineering": {
        "model": "zai-org/GLM-5"
      },
      "deep": {
        "model": "anthropic/claude-opus-4.6"
      },
      "ultrabrain": {
        "model": "openai/gpt-5.4-codex"
      },
      "quick": {
        "model": "zai-org/GLM-5"
      }
    }
  },
  "settings": {
    "language": "zh-CN",
    "theme": "dark",
    "show_model_list": false
  }
}