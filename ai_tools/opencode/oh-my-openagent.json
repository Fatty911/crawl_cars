{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "disabled_hooks": [
    "auto-slash-command"
  ],
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [
      400,
      401,
      403,
      408,
      409,
      423,
      425,
      429,
      500,
      501,
      502,
      503,
      504,
      505,
      506,
      507,
      508,
      509,
      510,
      511,
      520,
      521,
      522,
      523,
      524,
      525,
      526,
      527,
      529,
      530
    ],
    "error_patterns_to_fallback": [
      "Internal Server Error",
      "Bad Gateway",
      "Request failed",
      "model request failed",
      "status: 500",
      "status: 502",
      "status: 503",
      "service unavailable",
      "temporarily unavailable",
      "try again",
      "timeout",
      "ECONNREFUSED",
      "ENOTFOUND",
      "ECONNRESET",
      "network error",
      "stream closed",
      "connection reset",
      "Too Many Requests",
      "you've exceeded",
      "weekly rate limit",
      "rate limit exceeded",
      "rate_limit",
      "quota exceeded",
      "quota will be refreshed",
      "quota-upgrade",
      "insufficient quota",
      "insufficient account balance",
      "usage limit",
      "limit exceeded",
      "billing cycle",
      "capacity",
      "Remote validation failed",
      "authentication requests failed",
      "超过套餐",
      "用量已超过",
      "配额",
      "额度",
      "限流",
      "小时限制",
      "每周限制",
      "请等用量刷新"
    ],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 20,
    "timeout_seconds": 10,
    "notify_on_fallback": true
  },
  "agents": {
    "sisyphus": {
      "model": "mimo-tokenplan/mimo-v2.5-pro",
      "fallback_models": [
        "volcengine-coding/kimi-k2.6",
        "mimo-tokenplan/mimo-v2.5-pro",
        "nvidia/nvidia-glm-5.1",
        "nvidia/nvidia-kimi-k2.6",
        "deepseek/deepseek-v4-pro",
        "volcengine-coding/deepseek-v4-pro",
        "cloudflare-workers-ai/cf-kimi-k2.6",
        "proxy_openrouter/openrouter-kimi-k2.6-free",
        "proxy_xai/grok-4.3",
        "deepseek/deepseek-v4-flash"
      ]
    },
    "plan": {
      "model": "mimo-tokenplan/mimo-v2.5-pro",
      "fallback_models": [
        "volcengine-coding/kimi-k2.6",
        "mimo-tokenplan/mimo-v2.5-pro",
        "nvidia/nvidia-glm-5.1",
